# Get your key at https://www.memelord.com/settings/developer
# Format: mlord_live_xxxxxxxx (paste the full token after Bearer in their docs)
MEMELORD_API_KEY=mlord_live_YOUR_API_KEY

# Vercel AI Gateway — create a key at: Vercel dashboard → AI → AI Gateway → API keys
# On Vercel deployments this is often injected automatically when AI Gateway is enabled.
AI_GATEWAY_API_KEY=vck_YOUR_AI_GATEWAY_KEY

# Optional: override default model (provider/model id routed by the gateway)
# AI_GATEWAY_MODEL=anthropic/claude-sonnet-4.6
